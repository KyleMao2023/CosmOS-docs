          </mxGeometry>
        </mxCell>
        <mxCell id="trampoline" value="&lt;b&gt;Trampoline&lt;/b&gt;&lt;br&gt;最高跳板页&lt;br&gt;trap 入口 / 返回代码&lt;br&gt;用户态与内核态切换共享" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#D97706;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="150" width="210" height="58" as="geometry" />
        </mxCell>
        <mxCell id="trap_ctx" value="&lt;b&gt;TrapContext pages&lt;/b&gt;&lt;br&gt;按线程编号向低地址分配；&lt;div&gt;每线程一页&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="215" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="stacks" value="&lt;b&gt;User stacks&lt;/b&gt;&lt;br&gt;USER_STACK_BASE地址起&lt;br&gt;每线程 USER_STACK_SIZE&lt;br&gt;相邻线程栈之间保留页间隔" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="292" width="210" height="75" as="geometry" />
        </mxCell>
        <mxCell id="mmap_area" value="&lt;b&gt;mmap area&lt;/b&gt;&lt;br&gt;USER_MMAP_BASE 附近自动选址&lt;br&gt;匿名 mmap / file-backed mmap&lt;br&gt;共享匿名映射 / 动态装载器映射" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="374" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="vdso" value="&lt;b&gt;vDSO / rt_sigreturn page&lt;/b&gt;&lt;br&gt;USER_MMAP_BASE后一页&lt;div&gt;用户可读可执行&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0D9488;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="462" width="210" height="62" as="geometry" />
        </mxCell>
        <mxCell id="heap" value="&lt;b&gt;Heap / brk&lt;/b&gt;&lt;br&gt;紧接 ELF 最高装载地址&lt;br&gt;start_brk 由 ELF 最大结束地址决定&lt;br&gt;brk / sbrk 扩展或收缩" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="531" width="210" height="75" as="geometry" />
        </mxCell>
        <mxCell id="elf" value="&lt;b&gt;ELF load segments&lt;/b&gt;&lt;br&gt;text / rodata / data / bss&lt;br&gt;由 ELF program header 装载&lt;br&gt;权限来自 ELF 段 flags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="105" y="613" width="210" height="75" as="geometry" />
        </mxCell>
        <mxCell id="memory_set" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontSize=18;fontStyle=1;spacing=8;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="460" y="95" width="350" height="390" as="geometry" />
        </mxCell>
        <mxCell id="vma_tree" value="&lt;b&gt;VMA tree&lt;/b&gt;&lt;br&gt;按虚拟区间组织&lt;br&gt;保存映射语义：range / perm / map_type / offset / file&lt;br&gt;用于 mmap / brk / page fault / unmap / fork" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#1D4ED8;fontSize=14;spacing=8;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="500" y="160" width="270" height="130" as="geometry" />
        </mxCell>
        <mxCell id="pagetable" value="&lt;b&gt;PageTable&lt;/b&gt;&lt;br&gt;硬件页表状态&lt;br&gt;VPN → PPN + flags&lt;br&gt;真正决定 CPU 访存翻译与权限检查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=14;spacing=8;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="500" y="325" width="270" height="115" as="geometry" />
        </mxCell>
        <mxCell id="semantics_note" value="&lt;b&gt;核心关系&lt;/b&gt;&lt;br&gt;VMA 是“应该怎么映射”的语义元数据；PageTable 是“当前已经怎么映射”的硬件状态。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;fontSize=12;spacing=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="485" y="545" width="300" height="70" as="geometry" />
