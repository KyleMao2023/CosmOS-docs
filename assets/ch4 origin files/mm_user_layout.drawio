          <mxGeometry x="50" y="135" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="low_label" value="低地址" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#475569;" parent="1" vertex="1">
