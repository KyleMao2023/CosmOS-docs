        <mxCell id="lane_mm" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4FF;strokeColor=#8BBBE8;strokeWidth=2;arcSize=10;labelBackgroundColor=none;" parent="1" vertex="1">
