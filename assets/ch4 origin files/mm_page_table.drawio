  <diagram id="mm-page-table-hal" name="mm_page_table">
    <mxGraphModel dx="1406" dy="907" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="720" math="0" shadow="0">
