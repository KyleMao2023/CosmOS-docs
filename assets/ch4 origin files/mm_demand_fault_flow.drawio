        <mxCell id="v70" value="&lt;b&gt;PTE 更新完成&lt;/b&gt;&lt;br&gt;用户态重试 fault 指令" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;arcSize=10;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1140" y="835" width="220" height="58" as="geometry" />
