        </mxCell>
        <mxCell id="8be7dEwbe0AuUS0FuVEA-15" value="&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;b style=&quot;&quot;&gt;图例&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;background-color: rgb(255, 242, 204);&quot;&gt;VMA&amp;amp;PTE&amp;nbsp;&lt;/span&gt;：VMA元数据与页表&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;span style=&quot;background-color: rgb(225, 213, 231);&quot;&gt;PrivatePage &lt;/span&gt;：匿名/私有物化页&lt;br&gt;&lt;span style=&quot;background-color: rgb(213, 232, 212);&quot;&gt; CachePage &lt;/span&gt;：文件页缓存&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;strokeWidth=1.2;arcSize=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="770" width="350" height="140" as="geometry" />
