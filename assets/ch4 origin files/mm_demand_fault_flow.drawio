        <mxCell id="e75" value="PTE 替换后" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;fontSize=11;dashed=1;dashPattern=6 4;labelBackgroundColor=none;labelPosition=center;verticalLabelPosition=top;align=center;verticalAlign=bottom;" parent="1" source="v70" target="v71" edge="1">
