        </mxCell>
        <mxCell id="8be7dEwbe0AuUS0FuVEA-3" value="&lt;div style=&quot;&quot;&gt;根据 VMA 语义分流&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;vma.kind + flags&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;+ fault type&lt;/span&gt;&lt;span style=&quot;font-size: 0px; text-wrap: nowrap; color: rgba(0, 0, 0, 0); font-family: monospace; background-color: transparent;&quot;&gt;vma.kind + flags + fault type&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="920" y="160" width="160" height="99" as="geometry" />
        </mxCell>
        <mxCell id="8be7dEwbe0AuUS0FuVEA-4" value="&lt;b&gt;此时通常只更新 VMA 元数据；&lt;/b&gt;&lt;div&gt;&lt;b&gt;PTE 可以暂时为空，不立即分配物理页。&lt;/b&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#e51400;strokeColor=#B20000;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="75" y="613.5" width="275" height="115" as="geometry" />
        </mxCell>
        <mxCell id="8be7dEwbe0AuUS0FuVEA-5" value="&lt;b style=&quot;font-size: 13px;&quot;&gt;VMA 是所有分流的依据&lt;/b&gt;&lt;br style=&quot;font-size: 13px; font-weight: 700;&quot;&gt;&lt;span style=&quot;font-size: 13px; font-weight: 700;&quot;&gt;缺页处理不猜测来源；&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 13px; font-weight: 700;&quot;&gt;根据命中的 VMA 语义选择装页策略。&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#e51400;strokeColor=#B20000;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="475" y="740" width="275" height="115" as="geometry" />
