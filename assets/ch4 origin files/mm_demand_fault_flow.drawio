        <mxCell id="8be7dEwbe0AuUS0FuVEA-17" value="&lt;br&gt;&lt;div&gt;&lt;span style=&quot;font-size: 13px; font-weight: 700;&quot;&gt;赖分配、COW、PageCache实现；&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 13px; font-weight: 700;&quot;&gt;申请、复制、访问内存空间时&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 13px; font-weight: 700; background-color: transparent; color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18));&quot;&gt;只在必要时发生复制、修改&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#e51400;strokeColor=#B20000;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="887.5" y="783" width="225" height="110" as="geometry" />
